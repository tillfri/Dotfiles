{
    "layer": "top",
    "output":["DP-2"],
    "position": "top",
    "mod": "dock",
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "height": 34,
    "margin-right": 10,
    "margin-left": 10,
    "margin-top": 2,
    "margin-bottom": 0,
    "modules-left": [
	"cpu",
	"temperature",
	"memory",
    ],
    "modules-center": [
	"hyprland/workspaces",
    ],
    "modules-right": [
	"custom/updates",
	"network",
	"tray",
        "pulseaudio",
        "pulseaudio#microphone",
        "battery",
        "clock",
    ],
    
    "clock": {
        "format": "ï€— {:%H:%M}",
        "timezone": "Europe/Berlin"
    },

    "network": {
        "tooltip": true,
        "format-wifi": "<span foreground='#FFFFFF'>ï€™ {bandwidthDownBytes}</span> <span foreground='#FFFFFF'>ï‚“ {bandwidthUpBytes}</span>",
        "format-ethernet": "<span foreground='#FFFFFF'>ï€™ {bandwidthDownBytes}</span> <span foreground='#FFFFFF'>ï‚“ {bandwidthUpBytes}</span>",
        "tooltip-format": "Network: <big><b>{essid}</b></big>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>\nIP: <b>{ipaddr}/{cidr}</b>\nGateway: <b>{gwaddr}</b>\nNetmask: <b>{netmask}</b>",
        "format-linked": "َ°ˆ€ {ifname} (No IP)",
        "format-disconnected": " َ°–ھ ",
        "tooltip-format-disconnected": "Disconnected",
        "interval": 5,
    },

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "on-click": "activate",
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": []
        }
    },

    "hyprland/window": {
        "format": "{}",
        "rewrite": {
            "^n( .*)?$": "îں… $1",
            "^y( .*)?$": "ïپ¼ $1",
            "^lg( .*)?$": "َ°ٹ¢ lazygit $1",
            "^Yazi:( .*)?$": "ïپ¼ $1",
            "^yazi( .*)?$": "ïپ¼ $1",
            "^(.*) â€” Mozilla Firefox$": "ï‰©  $1",
            "^(.*) - Mozilla Firefox$": "ï‰©  $1",
            "^(.*) - Obsidian v[0-9.]+$": "ًں—’ $1",
            "^(.*) - Discord$": "ï‡؟  $1",
        },
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "َ°›گ",
            "deactivated": "َ°›‘"
        },
        "tooltip": true
    },

    "custom/power_btn": {
        "format": "ïŒƒ",
        "on-click": "sh -c '(sleep 0.5s; wlogout --protocol layer-shell)' & disown",
        "tooltip": false
    },

    "cpu": {
        "interval": 5,
        "format": "ï‹› {usage}%",
        "max-length": 10,
        "format-alt-click": "click-right",
        "format-alt": "ï‹› {usage}%",
        "on-click": "kitty --start-as=fullscreen --title btop sh -c 'btop'"
    },

    "memory": {
	"interval": 5,
        "format": "ïƒ‰ {used}GiB"
    },

    "disk": {
        "interval": 30,
        "format": "َ°‹ٹ {percentage_used}%",
        "path": "/",
        "tooltip": true,
        "tooltip-format": "HDD - {used} used out of {total} on {path} ({percentage_used}%)",
        "on-click": "kitty --start-as=fullscreen --title btop sh -c 'btop'"
    },

    "temperature": {
	"hwmon-path-abs": "/sys/devices/pci0000:00/0000:00:18.3/hwmon",
	"input-filename": "temp1_input",
        "format": "ï‹‰ {temperatureC}آ°C",
	"interval": 5,
    },

    "battery": {
        "states": {
            "good": 80,
            "warning": 30,
            "critical": 20
        },
	"interval": 10,
        "format": "{icon} {capacity}%",
        "format-charging": "ï‡¦ {capacity}%",
        "format-plugged": "ï‡¦ {capacity}%",
        "format-alt-click": "click-right",
        "format-alt": "{icon} {capacity}%",
        "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
    },

    "pulseaudio": {
        "format": "{icon}",
        "format-muted": "ï‘¦",
        "on-click": "~/.config/waybar/scripts/volume --toggle",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "~/.config/waybar/scripts/volume --inc",
        "on-scroll-down": "~/.config/waybar/scripts/volume --dec",
        "scroll-step": 5,
        "format-icons": {
            "headphone": "ï€¥",
            "hands-free": "ï€¥",
            "headset": "ï€¥",
            "phone": "ï‚•",
            "portable": "ï‚•",
            "car": "ï†¹",
            "default": ["ï€¦", "ï€§", "ï€¨"]
        },
        "tooltip": true,
        "tooltip-format": "{icon} at {volume}%"
    },

    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "ï„°",
        "format-source-muted": "ï„±",
        "on-click": "~/.config/waybar/scripts/volume --toggle-mic",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "~/.config/waybar/scripts/volume --mic-inc",
        "on-scroll-down": "~/.config/waybar/scripts/volume --mic-dec",
        "scroll-step": 5,
        "tooltip": true,
        "tooltip-format": "ï„° at {volume}%"
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "format-alt-click": "click-right",
        "format-alt": "{icon} {percent}%",
        "format-icons": ["َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
        "on-scroll-up": "~/.config/waybar/scripts/brightness --inc",
        "on-scroll-down": "~/.config/waybar/scripts/brightness --dec"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 10
    },

    "custom/updates": {
        "format": "{}",
        "exec": "~/.config/waybar/scripts/update-sys",
        "on-click": "~/.config/waybar/scripts/update-sys update",
        "interval": 900,
        "tooltip": true
    }
}
